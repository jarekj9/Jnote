# Admin account (overrides default random password at first start)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@jnote.local
ADMIN_PASSWORD=

# JWT signing secret (CHANGE THIS in production)
JWT_SECRET=change-me-to-a-long-random-string

# Google OAuth (leave empty to disable Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8080/api/auth/google/callback

# Public origin used for OAuth redirects / CORS
PUBLIC_ORIGIN=http://localhost:8080

# Where the SQLite file lives (mounted as a volume in docker)
DB_PATH=/data/jnote.sqlite
