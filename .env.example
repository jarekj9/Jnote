JWT_SECRET=replace-with-a-long-random-string
JWT_TTL=604800
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@jnote.local
ADMIN_PASSWORD=
# Google OIDC: leave both empty to disable
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Authelia (or any OIDC provider): set all three to enable.
# AUTHELIA_ISSUER = base URL of the Authelia instance (no trailing slash).
# Register this callback URL in Authelia:
#   ${AUTHELIA_ISSUER}/api/auth/oidc/authelia/callback
AUTHELIA_ISSUER=
AUTHELIA_CLIENT_ID=
AUTHELIA_CLIENT_SECRET=
AUTHELIA_NAME=Authelia
PUBLIC_ORIGIN=http://localhost:8080
HOST_PORT=8080
COOKIE_SECURE=0
TRUST_PROXY_HOPS=1
PASSWORD_MIN_LENGTH=8
RATE_LIMIT_LOGIN=10
RATE_LIMIT_REGISTER=5
RATE_LIMIT_IMPORT=5
